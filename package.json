{
    "name": "vscode-capnp",
    "displayName": "Cap'n Proto (xmonader)",
    "description": "Cap'n Proto language support for VS Code — syntax highlighting, bracket matching, and ID generation",
    "version": "1.1.0",
    "publisher": "xmonader",
    "author": "Ahmed T. Youssef <xmonader@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/xmonader/vscode-capnp"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [],
    "main": "./out/src/extension",
    "contributes": {
        "commands": [
            {
                "command": "extension.generateCapnpID",
                "title": "Generate Capnp ID"
            }
        ],
        "languages": [
            {
                "id": "capnp",
                "aliases": [
                    "Cap'n Proto",
                    "capnp"
                ],
                "extensions": [
                    ".capnp"
                ],
                "configuration": "./capnp.configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "capnp",
                "scopeName": "source.capnp",
                "path": "./syntaxes/capnp.tmLanguage"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "tsc -p ./",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "test": "node ./out/test/runTest.js"
    },
    "dependencies": {
        "capnpid": ">0.1.2"
    },
    "devDependencies": {
        "@types/vscode": "^1.75.0",
        "@types/node": "^18.0.0",
        "@types/mocha": "^10.0.0",
        "typescript": "^5.0.0",
        "mocha": "^10.0.0",
        "@vscode/test-electron": "^2.3.0",
        "glob": "^8.0.0",
        "@types/glob": "^8.0.0",
        "@vscode/vsce": "^2.15.0",
        "ovsx": "^0.8.0"
    }
}
